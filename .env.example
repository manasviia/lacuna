# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required
OPENAI_API_KEY=sk-...

# Model selection (defaults shown)
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o

# Chunking — adjust based on document type and observed retrieval quality
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K_RETRIEVAL=6

# Evaluation — answers scoring <= this on the 0–3 scale are flagged as gaps
GAP_SCORE_THRESHOLD=1

# Storage paths (relative to project root)
SESSION_LOG_DIR=./logs
CHROMA_PERSIST_DIR=./chroma_db
